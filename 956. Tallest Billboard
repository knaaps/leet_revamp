class Solution:
    def tallestBillboard(self, rods: list[int]) -> int:
        memo = {}
        
        def dfs(i, diff):
            if i == len(rods):
                return 0 if diff == 0 else float('-inf')
            
            state = (i, diff)
            if state in memo:
                return memo[state]
            
            memo[state] = max(
                dfs(i + 1, diff),
                rods[i] + dfs(i + 1, diff + rods[i]),
                dfs(i + 1, diff - rods[i])
            )
            return memo[state]
    
        result = dfs(0, 0)
        return result if result > 0 else 0
