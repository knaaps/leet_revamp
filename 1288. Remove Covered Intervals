class Solution:
    def removeCoveredIntervals(self, intervals: List[List[int]]) -> int:
        intervals.sort(key = lambda x: (x[0], -x[1]))
        prev_sta, prev_end = -1, -1
        res = len(intervals)

        for sta, end in intervals:
            if prev_end >= end and prev_sta <= sta:
                res -= 1
            if end > prev_end:
                prev_end = end
                prev_sta = sta
        
        return res
