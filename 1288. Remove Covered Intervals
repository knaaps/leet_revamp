class Solution:
    def removeCoveredIntervals(self, intervals: List[List[int]]) -> int:
        
        intervals.sort(reverse = True)
        n = len(intervals)
        count = 0

        for i in range(n):
            a,b = intervals[i]
            for j in range(i+1,n):
                c,d = intervals[j]
                if a >= c and b <= d:
                    count += 1
                    break

        return n - count
