class Solution:
    def smallestSubsequence(self, s: str) -> str:
        hm = {}
        for ch in s:
            hm[ch] = hm.get(ch,0) + 1

        in_stack = set()
        stack = []
        for ch in s:
            hm[ch] -= 1
            if ch in in_stack:
                continue
            while stack and hm[stack[-1]]>0 and stack[-1] > ch:
                in_stack.remove(stack.pop())
            stack.append(ch)
            in_stack.add(ch)
        return ''.join(stack)
