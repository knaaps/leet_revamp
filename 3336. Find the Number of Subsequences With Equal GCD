class Solution:
    def subsequencePairCount(self, nums: List[int]) -> int:
        @cache
        dfs(i, g1, g2):
          if i == n:
              return g1 == g2
      
          x = nums[i]
      
          return (
              dfs(i+1, g1, g2) +
              dfs(i+1, gcd(g1, x), g2) +
              dfs(i+1, g1, gcd(g2, x))
          )
