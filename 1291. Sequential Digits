class Solution:
    def sequentialDigits(self, low: int, high: int) -> List[int]:
        s = "123456789"
        ans = []

        for i in range(len(s)):
            for j in range(i + 1, len(s) + 1):
                curr = int(s[i:j])
                if low <= curr <= high:
                    ans.append(curr)
        ans.sort()
        return ans
